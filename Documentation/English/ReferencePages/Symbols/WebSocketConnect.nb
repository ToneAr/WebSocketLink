Notebook[{

Cell[CellGroupData[{
Cell["WebSocketConnect", "ObjectName",ExpressionUUID->"bd616f49-7fff-481a-823d-d50f4cdc086f"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"164de546-429b-4e7b-9508-ef5756062391"],
 Cell[BoxData[
  TagBox[
   RowBox[{"WebSocketConnect", "[", "address", "]"}],
   HoldForm]], "InlineFormula",ExpressionUUID->
  "40d5c4f4-ff9c-464d-baea-f17bb7a1430e"],
 "\[LineSeparator]connects to a WebSocket server at ",
 Cell[BoxData[
  TagBox["address",
   HoldForm]], "InlineFormula",ExpressionUUID->
  "306b98f3-18dd-4327-87ea-c32c813d4071"],
 "."
}], "Usage",
 CellChangeTimes->{{3.986292130922888*^9, 
  3.986292131408824*^9}},ExpressionUUID->"4c35fe22-898b-4ca4-9935-\
b212bda94063"],

Cell["The following options can be given: ", "Notes",ExpressionUUID->"f0016964-883c-4b8f-b90b-720b8d4201ab"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "c291eca1-5d3d-4878-b659-dff26263942a"], "\"\<GUID\>\"", 
    TagBox["\"\<258EAFA5-E914-47DA-95CA-C5AB0DC85B11\>\"",
     HoldForm], Cell["\<\
WebSocket GUID used when validating the handshake accept key.\
\>", "TableText",ExpressionUUID->"9db42732-3c9e-42eb-bbbb-e4054a95a83b"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "83b89b42-b0c1-4885-b2c5-ecc0d285d6b8"], "\"\<MaxStoredMessages\>\"", 
    TagBox["1000",
     HoldForm], Cell["\<\
Maximum number of received messages retained in the client message buffer.\
\>", "TableText",ExpressionUUID->"c6e16ff6-9679-45a7-9e35-825a6ae3f63b"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "69afed02-9f25-43ad-87e6-a4299545f939"], "\"\<VerifyPeer\>\"", 
    TagBox["True",
     HoldForm], Cell["\<\
Whether to validate the TLS server certificate for WSS connections.\
\>", "TableText",ExpressionUUID->"8a47ed23-6abd-43f9-a040-43ba5fbcad6f"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "5f0ae143-95a2-46fb-a972-65516604f837"], "\"\<ReadTimeout\>\"", 
    TagBox["5.`",
     HoldForm], Cell["\<\
Maximum number of seconds to wait for a message when reading from a client \
object.\
\>", "TableText",ExpressionUUID->"1b4c47f7-65e7-41fe-8260-ca60ac72eefa"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "df0fab8f-cb3a-4775-a457-194226d71abc"], "\"\<ReadPollInterval\>\"", 
    TagBox["0.01`",
     HoldForm], Cell["\<\
Polling interval, in seconds, used while waiting for a message.\
\>", "TableText",ExpressionUUID->"08687843-a3f0-4826-abea-874d9bc4fd4d"]}
  }]], "3ColumnTableMod",ExpressionUUID->"073f5723-8fa3-4def-bf28-\
4f1dc9a9aa19"],

Cell[TextData[{
 "Addresses beginning with ",
 Cell[BoxData["\"\<wss://\>\""], "InlineFormula",ExpressionUUID->
  "d8825e96-c87e-4ce5-b1bd-ecc486797ba2"],
 " use TLS. Addresses beginning with ",
 Cell[BoxData["\"\<ws://\>\""], "InlineFormula",ExpressionUUID->
  "f2aba6e6-fe4b-4054-ad52-248561232b51"],
 " use a plain socket."
}], "Notes",ExpressionUUID->"5c101734-b3ad-45c9-8394-7487b6806e80"],

Cell[TextData[{
 "With ",
 Cell[BoxData[
  TagBox[
   RowBox[{"\"\<VerifyPeer\>\"", "\[Rule]", "True"}],
   HoldForm]], "InlineFormula",ExpressionUUID->
  "dc3f1656-5753-445d-8487-2d970c4f0a15"],
 ", WSS connections use Java certificate validation. This is the default."
}], "Notes",ExpressionUUID->"9b308194-d52e-480d-a4d9-9dc70e6c77bc"],

Cell[TextData[{
 Cell[BoxData[
  TagBox[
   RowBox[{"\"\<VerifyPeer\>\"", "\[Rule]", "False"}],
   HoldForm]], "InlineFormula",ExpressionUUID->
  "cf6506e6-8732-4356-b46c-82b78e352c23"],
 " disables TLS certificate validation and should be used only for local \
testing with untrusted certificates."
}], "Notes",ExpressionUUID->"9e3e2ed4-e148-4c15-b0de-745778b97ca1"],

Cell[TextData[{
 "When connecting to a ",
 Cell[BoxData[
  TagBox["WebSocketServerStart",
   HoldForm]], "InlineFormula",ExpressionUUID->
  "db901ef4-3492-401c-93f4-c37d084d0596"],
 " server that uses the automatic TLS certificate in the same kernel, the \
generated certificate is trusted without disabling peer verification."
}], "Notes",ExpressionUUID->"7aebd92f-bfce-49ed-a1c9-e2aff03a2ab4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["See Also", "SeeAlsoSection",ExpressionUUID->"7fc70528-b72a-475f-ab94-42d0627e716f"],

Cell[TextData[{
 ButtonBox["WebSocketServerStart",
  BaseStyle->"Link",
  ButtonData->"paclet:ToneAr/WebSocketLink/ref/WebSocketServerStart"],
 " \[FilledVerySmallSquare] ",
 ButtonBox["WebSocketObject",
  BaseStyle->"Link",
  ButtonData->"paclet:ToneAr/WebSocketLink/ref/WebSocketObject"]
}], "SeeAlso",ExpressionUUID->"e80250ed-bd4b-444e-b309-8e40814cf5b3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples Initialization", "ExamplesInitializationSection",ExpressionUUID->"4b150b91-4119-42da-9108-891faa8bffaf"],

Cell[BoxData[
 TagBox[
  RowBox[{"Needs", "[", "\"\<ToneAr`WebSocketLink`\>\"", "]"}],
  HoldForm]], "Input",ExpressionUUID->"7ec8d888-3379-44ce-939c-122e417ba560"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Basic Examples", "PrimaryExamplesSection",ExpressionUUID->"d53c0d56-2a1a-4b3a-ba2a-606d9723ec0d"],

Cell["Start a local secure server:", "ExampleText",ExpressionUUID->"4251b32c-e398-48fb-bb60-4dc17ec689b8"],

Cell[BoxData[
 TagBox[
  RowBox[{"server", "=", 
   RowBox[{"WebSocketServerStart", "[", 
    RowBox[{"30000", ",", 
     RowBox[{"\"\<TLS\>\"", "\[Rule]", "True"}]}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"561232c7-573b-42ca-afab-89d2ba0f0d92"],

Cell["\<\
Connect to it using WSS. The automatically generated certificate is trusted \
in the same kernel session:\
\>", "ExampleText",ExpressionUUID->"3005164b-c1bc-43d8-840a-b98759edf7e5"],

Cell[BoxData[
 TagBox[
  RowBox[{"client", "=", 
   RowBox[{"WebSocketConnect", "[", "\"\<wss://localhost:30000\>\"", "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"bcd59bfa-09e9-4790-be62-b7c36f5a70c6"],

Cell["\<\
For a server with an untrusted certificate, peer verification can be disabled \
for local testing:\
\>", "ExampleText",ExpressionUUID->"0309ea08-a052-43d5-88ef-cea043c1f7d6"],

Cell[BoxData[
 TagBox[
  RowBox[{"client", "=", 
   RowBox[{"WebSocketConnect", "[", 
    RowBox[{"\"\<wss://localhost:30000\>\"", ",", 
     RowBox[{"\"\<VerifyPeer\>\"", "\[Rule]", "False"}]}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"88dedf9a-45b8-4036-8002-448bd8a3a018"],

Cell["Close the connection and server:", "ExampleText",ExpressionUUID->"56b53fda-e7bd-4255-8e54-1bdbde5eb5d1"],

Cell[BoxData[
 TagBox[
  RowBox[{"Close", "/@", 
   RowBox[{"{", 
    RowBox[{"client", ",", "server"}], "}"}]}],
  HoldForm]], "Input",ExpressionUUID->"fb17477f-707f-4912-b199-31b2257dda8d"]
}, Open  ]],

