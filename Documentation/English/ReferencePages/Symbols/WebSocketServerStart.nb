Notebook[{

Cell[CellGroupData[{
Cell["WebSocketServerStart", "ObjectName",ExpressionUUID->"78f7158b-0d91-4999-b2a5-a8c78f22fc6c"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"e2ff62cd-5e15-4673-b7d4-c802a33615b8"],
 Cell[BoxData[
  TagBox[
   RowBox[{"WebSocketServerStart", "[", "]"}],
   HoldForm]], "InlineFormula",ExpressionUUID->
  "37a6ad56-3590-4e9f-b57b-1002713a7708"],
 "\[LineSeparator]starts a new WebSocket server on any available port.\n",
 Cell["   ", "ModInfo",ExpressionUUID->"be3b976c-0556-4d2a-ac18-c1c0d06137dc"],
 Cell[BoxData[
  TagBox[
   RowBox[{"WebSocketServerStart", "[", "port", "]"}],
   HoldForm]], "InlineFormula",ExpressionUUID->
  "7b474e82-f203-4aed-b539-d5863435961e"],
 "\[LineSeparator]starts a new WebSocket server listening on ",
 Cell[BoxData[
  TagBox["port",
   HoldForm]], "InlineFormula",ExpressionUUID->
  "e6880143-1ad1-496c-8831-9dce40c28a90"],
 ".\n",
 Cell["   ", "ModInfo",ExpressionUUID->"4642450b-8605-40cf-a93b-212176ab0f92"],
 Cell[BoxData[
  TagBox[
   RowBox[{"WebSocketServerStart", "[", 
    RowBox[{"port", ",", 
     RowBox[{"\"\<TLS\>\"", "\[Rule]", "True"}]}], "]"}],
   HoldForm]], "InlineFormula",ExpressionUUID->
  "c62743b2-2421-4b8d-bb7c-5554b9266b4d"],
 "\[LineSeparator]starts a secure WebSocket server listening on ",
 Cell[BoxData[
  TagBox["port",
   HoldForm]], "InlineFormula",ExpressionUUID->
  "e4cc060f-cc57-4214-8c5a-5393e0e21aea"],
 "."
}], "Usage",ExpressionUUID->"3362ea5c-1a3b-46a4-9755-e08d3a49f6e4"],

Cell["The following options can be given: ", "Notes",ExpressionUUID->"677570a5-b55b-4669-9e86-010768f160de"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "f92d98db-cd62-4778-8627-1fb27e3d6853"], "\"\<GUID\>\"", 
    TagBox["\"\<258EAFA5-E914-47DA-95CA-C5AB0DC85B11\>\"",
     HoldForm], Cell[
    "WebSocket GUID used when computing the handshake accept key.", 
     "TableText",ExpressionUUID->"c0644c79-9393-4963-80bc-e1f0c285c6ce"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "5f4a7e13-2cc4-4b6c-884c-0b028a6ac7d7"], "\"\<Debug\>\"", 
    TagBox["False",
     HoldForm], Cell[
    "Whether to print debug messages for server events.", "TableText",
     ExpressionUUID->"cc670407-59d0-4deb-963a-ec899b2397e5"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "2cc9add9-585d-4392-b4ec-3e9c30d3dde0"], 
    TagBox["OverwriteTarget",
     HoldForm], 
    TagBox["True",
     HoldForm], Cell["\<\
Whether to close an existing listener on the selected internal listening port.\
\>", "TableText",ExpressionUUID->"f0e9210e-3ead-4f8f-863b-0b0476696dff"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "f32662c1-84f3-4e20-93fe-d08e1e3838f7"], "\"\<TLS\>\"", 
    TagBox["False",
     HoldForm], Cell["\<\
Whether to expose the server as a secure WebSocket endpoint using TLS.\
\>", "TableText",ExpressionUUID->"6376f245-ab8e-4f2e-820e-c2bd5a29e950"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "82757ab8-e374-401a-9806-c918df45b96e"], "\"\<Certificate\>\"", 
    TagBox["Automatic",
     HoldForm], Cell["\<\
TLS server certificate. Automatic generates an internal self-signed localhost \
certificate. A path to a PKCS#12/PFX or PEM file, PEM text, or {path, \
password} can also be supplied.\
\>", "TableText",ExpressionUUID->"3f42c0da-d630-4436-a774-6a51225dde76"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "45f719b7-c856-4c3b-bef0-3f34e10c5155"], "\"\<CertificatePassword\>\"", 
    TagBox["\"\<\>\"",
     HoldForm], Cell[
    "Password used when Certificate is a certificate file path.", "TableText",
     ExpressionUUID->"4c525dad-c496-457a-9418-cabe22ab9d2e"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "aad1a1cf-870b-41e9-a459-0686ebad2150"], "\"\<HandlerFunctions\>\"", 
    TagBox[
     RowBox[{"Association", "[", 
      RowBox[{
       RowBox[{"\"\<DataReceived\>\"", "\[Rule]", "Identity"}], ",", 
       RowBox[{"\"\<ClientConnected\>\"", "\[Rule]", "Identity"}], ",", 
       RowBox[{"\"\<ClientDisconnected\>\"", "\[Rule]", "Identity"}]}], "]"}],
     
     HoldForm], Cell["\<\
Functions called when data is received, a client connects, or a client \
disconnects.\
\>", "TableText",ExpressionUUID->"318f7842-9278-4295-93f8-62efcbe0cb19"]}
  }]], "3ColumnTableMod",ExpressionUUID->"6b50f0dd-cddd-4018-bc10-\
ef7725fd80a7"],

Cell[TextData[{
 Cell[BoxData[
  TagBox[
   RowBox[{"\"\<TLS\>\"", "\[Rule]", "True"}],
   HoldForm]], "InlineFormula",ExpressionUUID->
  "d8d2291b-f966-41d8-9421-4ed24eab3a69"],
 " starts a WSS endpoint. Plain WebSocket clients should use ",
 Cell[BoxData["\"\<ws://\>\""], "InlineFormula",ExpressionUUID->
  "cc0976a1-266f-43cc-9f02-6f722e16aa04"],
 "; TLS clients should use ",
 Cell[BoxData["\"\<wss://\>\""], "InlineFormula",ExpressionUUID->
  "1b7ffa78-bc26-41ca-81c4-174b608a06f4"],
 "."
}], "Notes",ExpressionUUID->"f7beb103-d539-485f-a6d1-6f0b2118a875"],

Cell[TextData[{
 "The automatic TLS certificate is intended for Wolfram-to-Wolfram local \
testing. ",
 Cell[BoxData[
  TagBox["WebSocketConnect",
   HoldForm]], "InlineFormula",ExpressionUUID->
  "b1b6ec78-1ee5-450f-8013-4bb37a7f1e06"],
 " trusts this generated certificate when connecting in the same kernel \
session."
}], "Notes",ExpressionUUID->"d11203ed-750c-43c0-9324-483397b3ad27"],

Cell["\<\
Browser and other external clients must trust the server certificate. For \
production or public testing, use a CA-trusted certificate. For local browser \
testing, use a locally trusted development certificate with Subject \
Alternative Names for localhost.\
\>", "Notes",ExpressionUUID->"084f00bb-ad5a-4567-9880-552a2c6ff6bc"]
}, Open  ]],

Cell[CellGroupData[{

Cell["See Also", "SeeAlsoSection",ExpressionUUID->"d2759790-6a70-463f-8fd5-caef73802d1d"],

Cell[TextData[{
 ButtonBox["WebSocketConnect",
  BaseStyle->"Link",
  ButtonData->"paclet:ToneAr/WebSocketLink/ref/WebSocketConnect"],
 " \[FilledVerySmallSquare] ",
 ButtonBox["WebSocketObject",
  BaseStyle->"Link",
  ButtonData->"paclet:ToneAr/WebSocketLink/ref/WebSocketObject"]
}], "SeeAlso",ExpressionUUID->"6ecc9265-2d5c-459b-9227-32d5cdabee51"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples Initialization", "ExamplesInitializationSection",ExpressionUUID->"5183bd0e-b8f0-4a4e-9541-69f2ea5a2249"],

Cell[BoxData[
 TagBox[
  RowBox[{"Needs", "[", "\"\<ToneAr`WebSocketLink`\>\"", "]"}],
  HoldForm]], "Input",ExpressionUUID->"796f9358-4b55-4dad-9ece-fd21e40c6ff9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Basic Examples", "PrimaryExamplesSection",ExpressionUUID->"103d5379-9c19-49b4-bd34-6a964ef0f0e7"],

Cell["\<\
Start a secure WebSocket server with an automatically generated localhost \
certificate:\
\>", "ExampleText",ExpressionUUID->"68462294-6ca6-4662-95a7-87c33c4fc2fe"],

Cell[BoxData[
 TagBox[
  RowBox[{"server", "=", 
   RowBox[{"WebSocketServerStart", "[", 
    RowBox[{"30000", ",", 
     RowBox[{"\"\<TLS\>\"", "\[Rule]", "True"}]}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"f32cfb89-9fc7-403a-aecd-ae22b252e43d"],

Cell["Connect from a Wolfram client in the same kernel using WSS:", \
"ExampleText",ExpressionUUID->"1ebb915a-4af3-40bb-9cd7-4fa6f07deb9e"],

Cell[BoxData[
 TagBox[
  RowBox[{"client", "=", 
   RowBox[{"WebSocketConnect", "[", "\"\<wss://localhost:30000\>\"", "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"c7355605-21a2-4b44-b530-9025b085a63b"],

Cell["\<\
For browser testing, create or provide a certificate trusted by the browser. \
One common local-development workflow is mkcert:\
\>", "ExampleText",ExpressionUUID->"ff56ae07-359b-4258-85e5-419db503eb35"],

Cell["\<\
mkcert -install
mkcert -pkcs12 localhost 127.0.0.1 ::1\
\>", "Program",ExpressionUUID->"55c4e115-c9e1-42f8-8d8f-527edfe95ac1"],

Cell["\<\
Start the server with a trusted PKCS#12 certificate. Use the password for the \
generated certificate file; mkcert PKCS#12 files usually use \"changeit\".\
\>", "ExampleText",ExpressionUUID->"1e4b8952-5dac-4a32-b1ff-8545051851e5"],

Cell[BoxData[
 TagBox[
  RowBox[{"server", "=", 
   RowBox[{"WebSocketServerStart", "[", 
    RowBox[{"30000", ",", 
     RowBox[{"\"\<TLS\>\"", "\[Rule]", "True"}], ",", 
     RowBox[{"\"\<Certificate\>\"", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<localhost+2.p12\>\"", ",", "\"\<changeit\>\""}], 
       "}"}]}]}], "]"}]}],
  HoldForm]], "Input",ExpressionUUID->"41fbda14-a4a8-42c7-89df-b86146547cac"],

Cell["\<\
A browser client can then connect with JavaScript if the certificate is \
trusted by the browser:\
\>", "ExampleText",ExpressionUUID->"7335c855-65c7-4b80-93f8-de9cb633e6ac"],

Cell["\<\
const ws = new WebSocket(\"wss://localhost:30000\");
ws.onopen = () => ws.send(\"hello from browser\");\
\>", "Program",ExpressionUUID->"e36f2016-2ccc-4682-9579-0690a38ca87a"],

Cell["Close the client and server when finished:", "ExampleText",ExpressionUUID->"a122394e-35f0-4d27-918e-0290bcb52016"],

Cell[BoxData[
 TagBox[
  RowBox[{"Close", "/@", 
   RowBox[{"{", 
    RowBox[{"client", ",", "server"}], "}"}]}],
  HoldForm]], "Input",ExpressionUUID->"3e8c38a1-c4b9-4215-af2a-9997e38670fe"]
}, Open  ]],

