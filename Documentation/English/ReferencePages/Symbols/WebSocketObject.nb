Cell["Common properties include:", "Notes",ExpressionUUID->"716192ff-5e1e-4db3-9e67-be3e5ad6c2eb"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "73150b73-ec12-49c8-8c4b-68c2f5edd30d"], "\"\<Type\>\"", Cell["\<\
Object type, such as \"WebSocketServer\", \"WebSocketClient\", or \
\"WebSocketClientConnection\".\
\>", "TableText",ExpressionUUID->"663afa5b-fe73-4f0f-ba7b-22c231a0e089"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "780c3801-df07-4357-a910-5f6009b3aaf5"], "\"\<UUID\>\"", Cell[
    "Unique identifier for the object.", "TableText",ExpressionUUID->
     "59486028-4e9d-4210-ab06-86f0d093167b"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "7ae50319-b65c-4c95-8214-1e8a6ca16ab7"], "\"\<Socket\>\"", Cell[
    "Underlying socket object.", "TableText",ExpressionUUID->
     "995efb3c-55b8-4e1e-a502-eff78f66f23b"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "0afd22f0-2770-438d-b946-b17dfc676fd3"], "\"\<Address\>\"", Cell[
    "Original client address for client objects.", "TableText",ExpressionUUID->
     "1e2edb57-a7a5-4883-b51c-eb568e0e2168"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "2ec14ba8-ca5f-4458-b3e1-f4170543d927"], "\"\<Port\>\"", Cell[
    "External listening port for server objects.", "TableText",ExpressionUUID->
     "9f5201db-45dd-4b89-8fec-1ac99dd7d2a8"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "1eb3c334-8605-4591-b8f6-75a84dad43d1"], "\"\<TLS\>\"", Cell[
    "Whether the server object was started as a TLS/WSS endpoint.", 
     "TableText",ExpressionUUID->"3071eb11-bc8c-42e3-9593-45d81b6e5d63"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "dfd627ba-ffd8-415f-a0c0-55c61f04bb1a"], "\"\<ConnectedClients\>\"", 
    Cell["\<\
Association of active server-side client connections for server objects.\
\>", "TableText",ExpressionUUID->"1fcd6d35-32b1-43fd-b588-a4e4ba5b4966"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "874b7a80-03c6-4c44-96bf-ec95492d22e6"], "\"\<Messages\>\"", Cell["\<\
Message buffer for client objects and server-side client connections.\
\>", "TableText",ExpressionUUID->"0cef28e0-0978-4972-b2fd-d9b8e313819d"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "ed40217c-bf49-4eb7-9129-f1c9c350456f"], "\"\<SendMessage\>\"", Cell[
    "Function used internally to send WebSocket messages.", "TableText",
     ExpressionUUID->"ecc88717-fbdd-4805-b935-2774735b04e9"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "1358c78d-d4c8-4fe8-933f-d5e9dd3517d2"], "\"\<GetMessage\>\"", Cell[
    "Function used internally to read WebSocket messages.", "TableText",
     ExpressionUUID->"07dd6ad9-7d39-4bcf-b8fc-7a584ac3292c"]}
  }]], "2ColumnTableMod",ExpressionUUID->"2baa749a-7f36-4022-8ba4-\
